# ---- Supabase ----------------------------------------------------------------
# Project URL + public key. Get both from the dashboard's "Connect" button
# (App Frameworks → Next.js), or Settings → API.
# The public/anon key is safe to expose in the browser; Row Level Security
# protects the data.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Newer Supabase projects: publishable key (starts with sb_publishable_).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR-KEY
# Older projects use an anon JWT instead — the app accepts either, so set ONE:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ---- Site --------------------------------------------------------------------
# Public origin, used to build "copy invitation link" URLs.
# Locally this can be http://localhost:3000; on Vercel set it to your domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
