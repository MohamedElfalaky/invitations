# ---- Supabase ----------------------------------------------------------------
# Project URL and anon (public) key.
# Supabase Dashboard → Project Settings → API.
# The anon key is safe to expose in the browser; Row Level Security protects data.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ---- Site --------------------------------------------------------------------
# Public origin, used to build "copy invitation link" URLs.
# Locally this can be http://localhost:3000; on Vercel set it to your domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
